#!/bin/bash
# 0day wrapper - finds 0panel.py relative to this script

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ ! -f "$SCRIPT_DIR/0panel.py" ]; then
    echo "0day: 0panel.py not found in $SCRIPT_DIR"
    echo "run setup.sh first"
    exit 1
fi

cd "$SCRIPT_DIR" || exit 1
exec python3 "$SCRIPT_DIR/0panel.py" "$@"
